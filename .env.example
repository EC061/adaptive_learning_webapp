# Database
# Use `DATABASE_URL` for local Prisma commands.
# Use `PROD_DATABASE_URL` in Docker/production; compose maps it to `DATABASE_URL`.
DATABASE_URL="postgresql://user:pass@host:5432/adaptive_learning"
PROD_DATABASE_URL="postgresql://user:pass@host:5432/adaptive_learning"

# Teacher signup restriction — share only with intended teachers
TEACHER_SIGNUP_TOKEN="your-secret-teacher-code"

# OpenAI
OPENAI_API_KEY=""
OPENAI_SERVICE_TIER="flex"
OPENAI_MODEL="gpt-5.1"
