# Database
# DATABASE_URL is used by Prisma directly (local dev).
# PROD_DATABASE_URL is mapped to DATABASE_URL by docker-compose for production.
# Use host.docker.internal (not localhost) in PROD_DATABASE_URL since the web
# container needs to reach Postgres running on the Docker host.
DATABASE_URL="postgresql://user:pass@localhost:5432/adaptive_learning"
PROD_DATABASE_URL="postgresql://user:pass@host.docker.internal:5433/adaptive_learning"

# Auth
AUTH_SECRET="generate-a-random-secret-here"

# Teacher signup restriction — share only with intended teachers
TEACHER_SIGNUP_TOKEN="your-secret-teacher-code"

# OpenAI
OPENAI_API_KEY=""
OPENAI_SERVICE_TIER="flex"
OPENAI_MODEL="gpt-5.1"

# Learning material uploads (S3 only). Use standard AWS env or IAM role on EC2.
AWS_REGION=""
AWS_S3_BUCKET=""
# Max upload size in bytes (default 52428800 = 50 MiB)
LEARNING_MATERIAL_MAX_BYTES="52428800"
# Optional: MinIO or LocalStack (path-style addressing is enabled when set)
AWS_S3_ENDPOINT=""
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY if not using IAM role
